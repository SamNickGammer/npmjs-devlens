{
  "name": "devlens-inspector",
  "version": "0.1.0",
  "description": "In-app network, log, and error inspector for React Native and React apps.",
  "license": "MIT",
  "author": "Om Prakash Bharati",
  "repository": {
    "type": "git",
    "url": "https://github.com/SamNickGammer/npmjs-devlens.git"
  },
  "homepage": "https://github.com/SamNickGammer/npmjs-devlens#readme",
  "bugs": {
    "url": "https://github.com/SamNickGammer/npmjs-devlens/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "development": "./src/web.tsx",
      "default": "./dist/web.js"
    },
    "./react-native": {
      "types": "./dist/react-native.d.ts",
      "development": "./src/react-native.tsx",
      "default": "./dist/react-native.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "debugger",
    "network",
    "logging",
    "inspector"
  ],
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  }
}